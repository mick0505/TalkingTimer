<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:text="Default Minutes"/>

        <EditText
            android:id="@+id/defaultMinutes"
            android:inputType="number"/>

        <TextView
            android:text="Default Seconds"/>

        <EditText
            android:id="@+id/defaultSeconds"
            android:inputType="number"/>

        <CheckBox
            android:id="@+id/voiceControl"
            android:text="Enable Voice Control"/>

        <CheckBox
            android:id="@+id/raiseVolume"
            android:text="Raise Media Volume on Start"/>

        <TextView
            android:text="Start Volume %"/>

        <EditText
            android:id="@+id/startVolume"
            android:inputType="number"/>

        <CheckBox
            android:id="@+id/finalBeeps"
            android:text="Enable Last 10 Second Beeps"/>

    </LinearLayout>

</ScrollView>
